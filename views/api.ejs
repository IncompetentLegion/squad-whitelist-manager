<div class="grid grid-cols-1 md:grid-cols-2" style="gap: 2rem;">
  <div>
    <div class="bg-surface border border-border rounded-lg p-6">
      <h3 class="font-bold mb-4">API Keys</h3>
      <form method="POST" action="/api">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="mb-4">
          <label class="block text-secondary text-sm mb-1">Whitelist Key</label>
          <input type="text" name="whitelist_key" value="<%= whitelistKey %>" class="input-field" placeholder="Secret to protect /whitelist endpoint">
          <p class="text-secondary text-xs mt-1">Used to protect the whitelist output. Leave blank to make it public.</p>
        </div>
        <div class="mb-6">
          <label class="block text-secondary text-sm mb-1">Seeding API Key</label>
          <div class="flex gap-2">
            <input type="text" name="seeding_key" id="seeding_key" value="<%= seedingKey %>" class="input-field" placeholder="Shared secret for the SquadJS plugin" required>
            <button type="button" class="btn btn-secondary" onclick="document.getElementById('seeding_key').value=Array.from(crypto.getRandomValues(new Uint8Array(3)),b=>b.toString(16).padStart(2,'0')).join('')" style="white-space:nowrap">Generate</button>
          </div>
          <p class="text-secondary text-xs mt-1">Used by SquadJS to report seeding data and query player progress.</p>
        </div>
        <div class="mb-6">
          <label class="flex items-center gap-2">
            <input type="checkbox" name="seeding_leaderboard_api" <% if (seedingLeaderboardApi) { %>checked<% } %>>
            <span class="text-sm">Enable public seeding leaderboard API</span>
          </label>
          <p class="text-secondary text-xs mt-1">Exposes seeding leaderboard data as JSON at /api/seeding.</p>
        </div>
        <button type="submit" class="btn btn-accent">Save</button>
      </form>
    </div>
  </div>

  <div class="flex flex-col gap-6">
    <div class="bg-surface border border-border rounded-lg p-6">
      <h3 class="font-bold mb-1">Whitelist Output</h3>
      <p class="text-secondary text-xs mb-4">Squad RemoteAdminListHosts format. Add this URL to your server config.</p>
      <div class="mb-3">
        <span class="inline-block text-xs font-bold px-2 py-0.5 rounded" style="background:rgba(63,185,80,0.15);color:#3fb950">GET</span>
        <span class="text-secondary text-xs ml-1">text/plain</span>
      </div>
      <div class="bg-page border border-border rounded p-3 mb-2" style="word-break:break-all">
        <code class="text-sm"><%= baseUrl %>/whitelist<% if (whitelistKey) { %>/<%= whitelistKey %><% } %></code>
      </div>
      <% if (!whitelistKey) { %>
      <p class="text-xs" style="color:var(--accent)">No key set — endpoint is public.</p>
      <% } %>
    </div>

    <div class="bg-surface border border-border rounded-lg p-6">
      <h3 class="font-bold mb-1">Seeding Report</h3>
      <p class="text-secondary text-xs mb-4">SquadJS plugin sends player data every 60 seconds.</p>
      <div class="mb-3">
        <span class="inline-block text-xs font-bold px-2 py-0.5 rounded" style="background:rgba(225,6,0,0.15);color:#e10600">POST</span>
        <span class="text-secondary text-xs ml-1">application/json</span>
      </div>
      <div class="bg-page border border-border rounded p-3 mb-3" style="word-break:break-all">
        <code class="text-sm"><%= baseUrl %>/seeding/report/<% if (seedingKey) { %><%= seedingKey %><% } else { %><span class="text-secondary">set a key first</span><% } %></code>
      </div>
      <% if (!seedingKey) { %>
      <p class="text-xs mb-3" style="color:var(--accent)">No seeding key set — endpoint will reject all requests.</p>
      <% } %>
      <div>
        <p class="text-secondary text-xs font-bold mb-1">Body</p>
        <div class="bg-page border border-border rounded p-3">
          <pre class="text-xs" style="margin:0;white-space:pre-wrap"><code>{
  "players": [
    { "steamId": "76561198...", "name": "PlayerName" }
  ]
}</code></pre>
        </div>
      </div>
      <div class="mt-3">
        <p class="text-secondary text-xs font-bold mb-1">Response</p>
        <div class="bg-page border border-border rounded p-3">
          <code class="text-xs">{ "ok": true, "processed": 12, "rewardsCreated": 1 }</code>
        </div>
      </div>
    </div>

    <div class="bg-surface border border-border rounded-lg p-6">
      <h3 class="font-bold mb-1">Seeding Progress</h3>
      <p class="text-secondary text-xs mb-4">Query a player's seeding progress and reward status.</p>
      <div class="mb-3">
        <span class="inline-block text-xs font-bold px-2 py-0.5 rounded" style="background:rgba(63,185,80,0.15);color:#3fb950">GET</span>
        <span class="text-secondary text-xs ml-1">application/json</span>
      </div>
      <div class="bg-page border border-border rounded p-3 mb-3" style="word-break:break-all">
        <code class="text-sm"><%= baseUrl %>/seeding/progress/<% if (seedingKey) { %><%= seedingKey %><% } else { %><span class="text-secondary">set a key first</span><% } %>/<span class="text-secondary">{steamId}</span></code>
      </div>
      <% if (!seedingKey) { %>
      <p class="text-xs mb-3" style="color:var(--accent)">No seeding key set — endpoint will reject all requests.</p>
      <% } %>
      <div>
        <p class="text-secondary text-xs font-bold mb-1">Response</p>
        <div class="bg-page border border-border rounded p-3">
          <pre class="text-xs" style="margin:0;white-space:pre-wrap"><code>{
  "steam_id": "76561198...",
  "player_name": "PlayerName",
  "points": 45,
  "points_needed": 60,
  "lifetime_points": 820,
  "last_seen_at": "2026-03-11 12:00:00",
  "has_reward": false,
  "reward_expires_at": null
}</code></pre>
        </div>
      </div>
    </div>

    <div class="bg-surface border border-border rounded-lg p-6">
      <h3 class="font-bold mb-1">Seeding Leaderboard</h3>
      <p class="text-secondary text-xs mb-4">Public JSON endpoint with player and clan seeding data.</p>
      <div class="mb-3">
        <span class="inline-block text-xs font-bold px-2 py-0.5 rounded" style="background:rgba(63,185,80,0.15);color:#3fb950">GET</span>
        <span class="text-secondary text-xs ml-1">application/json</span>
        <% if (seedingLeaderboardApi) { %>
        <span class="inline-block text-xs px-2 py-0.5 rounded ml-1" style="background:rgba(63,185,80,0.15);color:#3fb950">Public</span>
        <% } else { %>
        <span class="inline-block text-xs px-2 py-0.5 rounded ml-1" style="background:rgba(225,6,0,0.15);color:#e10600">Disabled</span>
        <% } %>
      </div>
      <div class="bg-page border border-border rounded p-3 mb-3" style="word-break:break-all">
        <code class="text-sm"><%= baseUrl %>/api/seeding</code>
      </div>
      <% if (!seedingLeaderboardApi) { %>
      <p class="text-xs mb-3" style="color:var(--accent)">Enable via the toggle on the left to activate this endpoint.</p>
      <% } %>
      <div>
        <p class="text-secondary text-xs font-bold mb-1">Response</p>
        <div class="bg-page border border-border rounded p-3">
          <pre class="text-xs" style="margin:0;white-space:pre-wrap"><code>{
  "enabled": true,
  "points_needed": 60,
  "reward_days": 7,
  "players": [
    {
      "steam_id": "76561198...",
      "player_name": "PlayerName",
      "points": 45,
      "lifetime_points": 820,
      "clan_name": "ClanTag",
      "last_seen_at": "2026-03-11 12:00:00",
      "has_reward": false
    }
  ],
  "clan_leaderboard": [
    {
      "clan_id": 1,
      "clan_name": "ClanTag",
      "seeder_count": 5,
      "total_lifetime_minutes": 4200
    }
  ]
}</code></pre>
        </div>
      </div>
    </div>
  </div>
</div>
