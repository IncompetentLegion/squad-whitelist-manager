<% if (success) { %>
<div class="bg-surface border border-accent rounded-lg p-4 mb-6">
  <h2 class="text-lg font-bold mb-2 text-accent">Invite Link Generated</h2>
  <p class="text-secondary text-sm mb-2">Share this link with the user. It expires in 7 days and can only be used once.</p>
  <div class="flex gap-2 items-center">
    <input type="text" readonly value="<%= success %>" id="invite-url" class="input-field flex-1 text-sm" onclick="this.select()">
    <button type="button" class="btn btn-accent" onclick="navigator.clipboard.writeText(document.getElementById('invite-url').value).then(() => this.textContent = 'Copied!').catch(() => document.getElementById('invite-url').select())">Copy</button>
  </div>
</div>
<% } %>

<div class="bg-surface border border-border rounded-lg p-4 mb-6">
  <h2 class="text-lg font-bold mb-3">Invite User</h2>
  <form method="POST" action="/users/invite" class="flex flex-wrap gap-3 items-end">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div>
      <label class="block text-secondary text-sm mb-1">Role</label>
      <select name="role" class="input-field w-32" onchange="document.getElementById('invite-clan').style.display = this.value === 'admin' ? 'none' : ''">
        <option value="manager">Manager</option>
        <option value="admin">Admin</option>
      </select>
    </div>
    <div id="invite-clan">
      <label class="block text-secondary text-sm mb-1">Clan</label>
      <select name="clan_id" class="input-field w-48">
        <option value="">Select a clan</option>
        <% clans.forEach(c => { %>
        <option value="<%= c.id %>"><%= c.name %></option>
        <% }) %>
      </select>
    </div>
    <button type="submit" class="btn btn-accent">Generate Invite</button>
  </form>
</div>

<% if (invites.length > 0) { %>
<div class="bg-surface border border-border rounded-lg p-4 mb-6">
  <h2 class="text-lg font-bold mb-3">Pending Invites</h2>
  <div class="overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Role</th>
          <th>Clan</th>
          <th>Created By</th>
          <th>Expires</th>
          <th>Link</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% invites.forEach(inv => { %>
        <tr>
          <td><span class="badge badge-<%= inv.role %>"><%= inv.role %></span></td>
          <td class="<%= inv.clan_name ? '' : 'text-secondary' %>"><%= inv.clan_name || '—' %></td>
          <td class="text-secondary text-sm"><%= inv.created_by_name || '—' %></td>
          <td class="text-secondary text-sm"><%= inv.expires_at.split(' ')[0] %></td>
          <td>
            <div class="flex gap-2 items-center">
              <input type="text" readonly value="<%= typeof success === 'string' && success.includes(inv.token) ? success : '/invite/' + inv.token %>" class="input-field text-xs w-48" onclick="this.select()">
            </div>
          </td>
          <td>
            <form method="POST" action="/users/invite/<%= inv.id %>/revoke" style="display:inline" onsubmit="return confirm('Revoke this invite?')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="action-link action-link--danger">Revoke</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<div class="bg-surface border border-border rounded-lg p-4">
<% if (users.length === 0) { %>
<p class="text-secondary">No users.</p>
<% } else { %>
<div class="overflow-x-auto">
  <table class="data-table">
    <thead>
      <tr>
        <th>Username</th>
        <th>Role</th>
        <th>Clan</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
      <tr>
        <td><%= u.username %></td>
        <td><span class="badge badge-<%= u.role %>"><%= u.role %></span></td>
        <td class="<%= u.clan_name ? '' : 'text-secondary' %>"><%= u.clan_name || '—' %></td>
        <td class="text-secondary text-sm"><%= u.created_at.split(' ')[0] %></td>
        <td>
          <div class="actions">
            <button type="button" class="action-link action-link--edit" onclick="toggleEdit('ue-<%= u.id %>')">Edit</button>
            <% if (u.id !== user.id && u.id !== 1) { %>
            <span class="sep">|</span>
            <form method="POST" action="/users/<%= u.id %>/delete" style="display:inline" onsubmit="return confirmDelete('user <%= u.username %>')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="action-link action-link--danger">Delete</button>
            </form>
            <% } %>
          </div>
        </td>
      </tr>
      <tr id="ue-<%= u.id %>" class="edit-row">
        <td colspan="5">
          <form method="POST" action="/users/<%= u.id %>/edit" class="flex flex-wrap gap-3 items-end">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div>
              <label class="block text-secondary text-xs mb-1">Username</label>
              <input type="text" name="username" value="<%= u.username %>" class="input-field text-sm w-40">
            </div>
            <div>
              <label class="block text-secondary text-xs mb-1">New Password</label>
              <input type="password" name="password" placeholder="Unchanged" class="input-field text-sm w-40">
            </div>
            <div>
              <label class="block text-secondary text-xs mb-1">Role</label>
              <select name="role" class="input-field text-sm w-36">
                <option value="manager" <%= u.role === 'manager' ? 'selected' : '' %>>Manager</option>
                <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
              </select>
            </div>
            <div>
              <label class="block text-secondary text-xs mb-1">Clan</label>
              <select name="clan_id" class="input-field text-sm w-48">
                <option value="">None</option>
                <% clans.forEach(c => { %>
                <option value="<%= c.id %>" <%= u.clan_id === c.id ? 'selected' : '' %>><%= c.name %></option>
                <% }) %>
              </select>
            </div>
            <button type="submit" class="btn btn-accent">Save</button>
            <button type="button" class="btn btn-secondary" onclick="toggleEdit('ue-<%= u.id %>')">Cancel</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>
</div>
