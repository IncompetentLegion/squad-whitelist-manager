<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Incompetent Legion</title>
  <link rel="icon" type="image/webp" href="/assets/logores.webp">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-page text-primary font-mono min-h-screen flex">
  <%- include('partials/nav') %>
  <div class="flex-1 ml-0 md:ml-56">
    <header class="border-b border-border px-6 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold"><%= title %></h1>
      <div class="flex items-center gap-4 text-sm text-secondary">
        <span><%= user.username %> (<%= user.role %>)</span>
        <a href="/logout" class="text-accent hover:underline">Logout</a>
      </div>
    </header>
    <main class="p-6">
      <%- include('partials/flash') %>
      <%- body %>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
